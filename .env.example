# --- Claude (Produkterkennung + Verkaufstext) ---
# API-Key von https://console.anthropic.com/  (oder `ant auth login` nutzen)
ANTHROPIC_API_KEY=sk-ant-...

# Optionaler Modell-Override. Default: claude-opus-4-8 (beste Erkennung + natürlichster Text).
# Kostenhebel bei hohem Volumen: claude-sonnet-5
FASTSELL_MODEL=claude-opus-4-8

# Modell für die dynamische Kategorie-Auswahl beim Posten. Beim Anzeigen-Aufgeben navigiert Claude
# den echten Kleinanzeigen-Kategoriebaum Ebene für Ebene und wählt auf jeder Ebene aus den tatsächlich
# vorhandenen Optionen (statt einen Pfad vorab zu raten). Das ist eine einfache Text-Klassifikation
# und wird mehrfach pro Anzeige aufgerufen -> Default ist das schnelle, günstige claude-haiku-4-5.
# FASTSELL_CATEGORY_MODEL=claude-haiku-4-5

# --- Session-Verschlüsselung ---
# 32-Byte-Key (hex, 64 Zeichen) zum Verschlüsseln des gespeicherten Kleinanzeigen-Logins.
# Leer lassen -> wird beim ersten Start automatisch in ./data/session.key erzeugt.
FASTSELL_ENC_KEY=

# --- Auto-Posting (Playwright) ---
# Chromium ist im Container vorinstalliert. Falls nötig, Pfad überschreiben:
# PLAYWRIGHT_CHROMIUM=/opt/pw-browsers/chromium
# Headless für Poster (Login läuft standardmäßig headful). true/false:
FASTSELL_POSTER_HEADLESS=false
# Einstieg-URL zum Anzeigen-Aufgeben überschreiben (falls Kleinanzeigen die URL ändert):
# FASTSELL_NEW_AD_URL=https://www.kleinanzeigen.de/p-anzeige-aufgeben.html
# Login kopflos ausführen (true = ohne Display, z. B. Server/Test). Default: false (sichtbarer Browser).
# FASTSELL_LOGIN_HEADLESS=false
# Wartezeit auf den manuellen Login in ms (Default 180000 = 3 Min).
# FASTSELL_LOGIN_TIMEOUT_MS=180000
