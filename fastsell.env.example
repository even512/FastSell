# FastSell – Container-Umgebung (wird von docker-compose als env_file geladen).
# Kopieren zu `fastsell.env` und Key eintragen. `fastsell.env` ist gitignored (nicht auf GitHub).
#   cp fastsell.env.example fastsell.env
ANTHROPIC_API_KEY=sk-ant-...
FASTSELL_MODEL=claude-opus-4-8
FASTSELL_POSTER_HEADLESS=true
# Optional: fester 32-Byte-Hex-Key zum Verschlüsseln der Login-Session (sonst auto in data/session.key)
# FASTSELL_ENC_KEY=
